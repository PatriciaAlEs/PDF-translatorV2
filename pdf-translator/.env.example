# Copy this file as .env and fill in your keys

# Gemini (recommended — generous FREE tier)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude (optional — paid)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Server port (optional, default: 5000)
PORT=5000
